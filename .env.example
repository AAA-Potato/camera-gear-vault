# Copy this file to .env.local and fill in your real Supabase values.
# The anon/publishable key is safe to expose in client-side code —
# access is controlled by Supabase Row Level Security policies.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_KEY=your-publishable-anon-key
